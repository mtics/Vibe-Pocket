# Keep this file as a template only. Do not commit a real token.
VIBE_POCKET_TOKEN=replace-with-output-from-openssl-rand-hex-32
VIBE_POCKET_HOST=127.0.0.1
VIBE_POCKET_PORT=4320
VIBE_POCKET_CODEX_COMMAND=/opt/homebrew/bin/codex
VIBE_POCKET_ENGINE=app-server
VIBE_POCKET_WORKSPACES={"workspace":"/absolute/path/to/allowed/workspace"}
VIBE_POCKET_OWNED_THREADS_PATH=/absolute/private/path/to/owned-threads.json
# Optional. Defaults to the current user's OS configuration directory.
# VIBE_POCKET_PROFILE_PATH=/absolute/path/to/controller-profile.json
